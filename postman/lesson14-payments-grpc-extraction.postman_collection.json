{
  "info": {
    "name": "Lesson 14 - Payments gRPC Extraction",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:3021"
    },
    {
      "key": "orderId",
      "value": "11111111-1111-1111-1111-111111111111"
    },
    {
      "key": "userId",
      "value": "22222222-2222-2222-2222-222222222222"
    },
    {
      "key": "idempotencyKey",
      "value": "lesson14-basic-001"
    },
    {
      "key": "paymentId",
      "value": ""
    }
  ],
  "item": [
    {
      "name": "0) GET /orders/health",
      "request": {
        "method": "GET",
        "url": "{{baseUrl}}/orders/health"
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('health ok', () => {",
              "  pm.expect(pm.response.code).to.eql(200);",
              "  const data = pm.response.json();",
              "  pm.expect(data.ok).to.eql(true);",
              "});"
            ]
          }
        }
      ]
    },
    {
      "name": "1) POST /orders/:id/pay",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "content-type",
            "value": "application/json"
          }
        ],
        "url": "{{baseUrl}}/orders/{{orderId}}/pay",
        "body": {
          "mode": "raw",
          "raw": "{\n  \"userId\": \"{{userId}}\",\n  \"amount\": \"99.90\",\n  \"currency\": \"USD\",\n  \"idempotencyKey\": \"{{idempotencyKey}}\"\n}",
          "options": {
            "raw": {
              "language": "json"
            }
          }
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('authorized', () => {",
              "  pm.expect(pm.response.code).to.be.oneOf([200, 201]);",
              "  const data = pm.response.json();",
              "  pm.expect(data).to.have.property('paymentId');",
              "  pm.collectionVariables.set('paymentId', data.paymentId);",
              "});"
            ]
          }
        }
      ]
    },
    {
      "name": "2) GET /orders/payments/:paymentId/status",
      "request": {
        "method": "GET",
        "url": "{{baseUrl}}/orders/payments/{{paymentId}}/status"
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('status fetched', () => {",
              "  pm.expect(pm.response.code).to.equal(200);",
              "  const data = pm.response.json();",
              "  pm.expect(data.paymentId).to.eql(pm.collectionVariables.get('paymentId'));",
              "});"
            ]
          }
        }
      ]
    }
  ]
}
